# Настройки PostgreSQL
POSTGRES_USER=gamemaster
POSTGRES_PASSWORD=gamemaster
POSTGRES_DB=gamemaster

# URL подключения к БД (localhost — для локальной разработки, в Docker переопределяется)
DATABASE_URL=postgresql+asyncpg://gamemaster:gamemaster@localhost:5432/gamemaster

# Секрет для подписи JWT (HS256). ОБЯЗАТЕЛЬНО поменять в проде на рандомную строку ≥32 chars.
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# CORS: домены frontend-клиентов, которым разрешены запросы к API.
# Принимается как JSON-массив или CSV. CRA — :3000, Vite — :5173.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Включает echo SQL-запросов в логах SQLAlchemy.
DEBUG=false
