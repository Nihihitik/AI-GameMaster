# ============================================================
# AI-GameMaster Frontend — пример переменных окружения
# ============================================================
# Скопируй этот файл в .env и при необходимости поправь значения:
#   cp .env.example .env
#
# Create React App (react-scripts) подхватывает только те переменные,
# которые начинаются с префикса REACT_APP_.
# ============================================================

# Корень REST API backend-сервера.
# К этому URL httpClient автоматически добавляет префикс /api.
# Dev (docker compose up в backend/):         http://localhost:8000
# Локальный backend через uv run uvicorn:     http://localhost:8000
REACT_APP_API_BASE_URL=http://localhost:8000

# Корень WebSocket-соединения backend-сервера.
# Полный путь формируется как ${WS_BASE_URL}/ws/sessions/{session_id}?token=...
# Dev:        ws://localhost:8000
# Production: wss://your-domain.example
REACT_APP_WS_BASE_URL=ws://localhost:8000

# Флаг использования клиентских mock-данных (mockGameEngine, sessionMocks и т.д.).
# "true"  — включить mock-режим (работа без backend, для UI-разработки).
# "false" — отключить моки, ходить в реальный API.
REACT_APP_USE_MOCKS=false
